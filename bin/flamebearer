#!/usr/bin/env node
import {loadInputs, formatReport} from '../index.js';

const HELP = `usage: flamebearer <input>... [options]

inputs: .json / .json.gz Chrome trace, .cpuprofile, or a directory of
        .cpuprofile files. Multiple inputs merge as additional threads.

filtering:
  --from <ms>           start of time range (relative to each thread's start)
  --to <ms>             end of time range
  --thread <name>       restrict to threads whose name contains <name>
                        (repeatable; matched case-insensitively)
  --top <N>             show at most N rows in Top CPU (default 20)
  --min-duration <ms>   hide Top CPU rows and long tasks shorter than <ms>

output:
  --color / --no-color  force ANSI color (default: on if TTY and !$NO_COLOR)
  --no-sourcemap        skip sibling .map / embedded sourcemap resolution
  --help, -h            show this help`;

const args = process.argv.slice(2);
if (!args.length || args.includes('--help') || args.includes('-h')) {
    console.log(HELP);
    process.exit(args.length ? 0 : 1);
}

const inputs = [];
const threads = [];
const opts = {};
let colorFlag = null;

for (let i = 0; i < args.length; i++) {
    const a = args[i];
    const next = () => {
        if (i + 1 >= args.length) { console.error(`missing value for ${a}`); process.exit(2); }
        return args[++i];
    };
    if (a === '--color') colorFlag = true;
    else if (a === '--no-color') colorFlag = false;
    else if (a === '--no-sourcemap') opts.sourceMaps = false;
    else if (a === '--from') opts.from = Number(next());
    else if (a === '--to') opts.to = Number(next());
    else if (a === '--thread') threads.push(next());
    else if (a === '--top') opts.top = Number(next());
    else if (a === '--min-duration') opts.minDuration = Number(next());
    else if (a.startsWith('--')) { console.error(`unknown option: ${a}`); process.exit(2); } else inputs.push(a);
}

opts.threads = threads;
opts.color = colorFlag ?? (process.stdout.isTTY && !process.env.NO_COLOR);

console.log(formatReport(loadInputs(inputs), opts));
console.log('\n(filters: --top N --thread NAME --from/--to MS --min-duration MS; --help for all)');
