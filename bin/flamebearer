#!/usr/bin/env node
import fs from 'node:fs';
import {parseTrace, formatReport} from '../index.js';

const args = process.argv.slice(2);
const file = args.find(a => !a.startsWith('--'));
if (!file) {
    console.error('usage: flamebearer <trace.json[.gz]> [--color | --no-color]');
    process.exit(1);
}

const color = args.includes('--color') || (!args.includes('--no-color') && process.stdout.isTTY && !process.env.NO_COLOR);

console.log(formatReport(parseTrace(fs.readFileSync(file)), {color}));
