#!/usr/bin/env node
import {parseArgs} from 'node:util';
import {loadInputs, formatReport} from '../index.js';

const HELP = `usage: flamebearer <input>... [options]

inputs: .json / .json.gz Chrome trace, .cpuprofile, or a directory of
        .cpuprofile files. Multiple inputs merge as additional threads.

filtering:
  --from <ms>           start of time range (relative to each thread's start)
  --to <ms>             end of time range
  --thread <name>       restrict to threads whose name contains <name>
                        (repeatable; matched case-insensitively)
  --top <N>             show at most N rows in Top CPU (default 10).
                        Note: the heaviest-stacks tree (default output) gives
                        a top-down view of where time goes; Top CPU is the
                        complementary bottom-up self-time leaderboard.
  --stacks <name>       drill into a function by exact name (case-insensitive):
                        callers, callees, and dominant descendant path.
                        Same name in multiple files = one block per file.

output:
  --color / --no-color  force ANSI color (default: on if TTY and !$NO_COLOR)
  --no-sourcemap        skip sibling .map / embedded sourcemap resolution
  --help, -h            show this help`;

let values, positionals;
try {
    ({values, positionals} = parseArgs({
        allowPositionals: true,
        options: {
            color: {type: 'boolean'},
            'no-color': {type: 'boolean'},
            'no-sourcemap': {type: 'boolean'},
            from: {type: 'string'},
            to: {type: 'string'},
            thread: {type: 'string', multiple: true},
            top: {type: 'string'},
            stacks: {type: 'string'},
            help: {type: 'boolean', short: 'h'}
        }
    }));
} catch (e) {
    console.error(e.message);
    process.exit(2);
}

if (values.help || !positionals.length) {
    console.log(HELP);
    process.exit(positionals.length ? 0 : 1);
}

const opts = {
    threads: values.thread ?? [],
    sourceMaps: !values['no-sourcemap'],
    color: values.color ?? (!values['no-color'] && process.stdout.isTTY && !process.env.NO_COLOR),
    from: values.from != null ? +values.from : undefined,
    to: values.to != null ? +values.to : undefined,
    top: values.top != null ? +values.top : undefined,
    stacks: values.stacks
};

console.log(formatReport(loadInputs(positionals), opts));
console.log('\n(drill down: --stacks <name>; filters: --top N --thread <name> --from/--to MS; see --help)');
